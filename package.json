{
  "name": "prism-quiz-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.runtime.json",
    "build:all": "tsc",
    "build:browser": "node scripts/build-browser.mjs",
    "typecheck:all": "tsc -p tsconfig.tests.json",
    "typecheck:harness": "tsc -p tsconfig.diagnostics.json",
    "harness:abstain-trump": "tsx src/diagnostics/realHarness.ts",
    "sim": "tsx src/test/simulation.ts",
    "sim:quick": "tsx src/test/simulation.ts --quick",
    "diagnostic": "tsx src/test/full-diagnostic.ts",
    "persona-replay": "tsx src/test/persona-replay.ts",
    "dump-replay": "tsx src/test/dump-replay.ts",
    "diagnose:party-mapping": "tsx src/diagnostics/partyMappingAudit.ts",
    "diagnose:personas": "tsx src/diagnostics/personaSuite.ts",
    "diagnose:defining": "tsx src/diagnostics/definingElectionsAudit.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
